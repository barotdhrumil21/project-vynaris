#!/usr/bin/env bash
# Vynaris installer for Linux / macOS.
# Creates venv, installs deps, starts Postgres (Docker or native), runs vynaris setup.
set -euo pipefail

GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'
say() { echo -e "${CYAN}==>${NC} $1"; }
ok()  { echo -e "${GREEN}  ✓${NC} $1"; }
warn(){ echo -e "${YELLOW}  !${NC} $1"; }
die() { echo -e "${RED}  ✗${NC} $1" >&2; exit 1; }

cd "$(dirname "$0")"

say "Vynaris installer"

# --- Python -----------------------------------------------------------------
if command -v python3 >/dev/null; then PY=python3
elif command -v python  >/dev/null; then PY=python
else die "Python 3.11+ required. Install from https://www.python.org"
fi
PYV=$($PY -c 'import sys;print(f"{sys.version_info.major}.{sys.version_info.minor}")')
PYM=$(echo "$PYV" | awk -F. '{print $1*100+$2}')
if [ "$PYM" -lt 311 ]; then die "Python 3.11+ required (found $PYV)"; fi
ok "Python $PYV"

# --- Node / claude CLI ------------------------------------------------------
if ! command -v node >/dev/null; then
    warn "Node.js not found — the Claude CLI requires it. Install from https://nodejs.org"
fi
if ! command -v claude >/dev/null; then
    if command -v npm >/dev/null; then
        say "installing Claude CLI via npm..."
        npm install -g @anthropic-ai/claude-code || warn "claude CLI install failed — install manually"
    else
        warn "claude CLI missing. Run: npm install -g @anthropic-ai/claude-code"
    fi
fi
command -v claude >/dev/null && ok "Claude CLI $(claude --version 2>/dev/null | head -1)"

# --- Postgres ---------------------------------------------------------------
say "checking Postgres on localhost:5432..."
if command -v pg_isready >/dev/null && pg_isready -h localhost -p 5432 -q 2>/dev/null; then
    ok "Postgres already running on :5432"
elif command -v docker >/dev/null && docker info >/dev/null 2>&1; then
    say "starting Postgres via docker compose..."
    docker compose up -d postgres
    for i in {1..30}; do
        docker compose exec -T postgres pg_isready -U vynaris -d vynaris >/dev/null 2>&1 && break
        sleep 1
    done
    ok "Postgres running in Docker"
else
    warn "No running Postgres found and Docker not available. Install Postgres or start Docker Desktop, then rerun."
    exit 1
fi

# --- venv + deps ------------------------------------------------------------
if [ ! -d .venv ]; then
    say "creating Python venv..."
    $PY -m venv .venv
fi
. .venv/bin/activate
say "installing Python dependencies..."
pip install -q --upgrade pip
pip install -q -e .
ok "dependencies installed"

# --- run setup --------------------------------------------------------------
say "running vynaris setup..."
python -m vynaris setup

ok "install complete"
echo
echo "  Start Vynaris:   ${GREEN}.venv/bin/vynaris start${NC}"
echo "  Open in browser: ${GREEN}.venv/bin/vynaris open${NC}"
echo
