# Vynaris configuration — copy to .env and fill in
# The install script will generate this for you on first run.

# Anthropic API key — OPTIONAL.
# Leave blank to use Claude CLI subscription auth (recommended if you already
# have Claude Code logged in). If you set a key here, it takes precedence.
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://vynaris:vynaris_dev_password_change_me@localhost:5432/vynaris

# App
VYNARIS_HOST=127.0.0.1
VYNARIS_PORT=7878
VYNARIS_SECRET_KEY=change-me-to-a-long-random-string
VYNARIS_DATA_DIR=./vynaris-data
VYNARIS_ENV=dev

# Models
VYNARIS_MODEL=claude-sonnet-4-5
VYNARIS_PLANNING_MODEL=claude-opus-4-5
