# Vynaris configuration — copy to .env and fill in
# The install script will generate this for you on first run.

# Anthropic API key — OPTIONAL.
# Leave blank to use Claude CLI subscription auth (recommended if you already
# have Claude Code logged in). If you set a key here, it takes precedence.
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://vynaris:vynaris_dev_password_change_me@localhost:5432/vynaris

# App
VYNARIS_HOST=127.0.0.1
VYNARIS_PORT=7878
VYNARIS_SECRET_KEY=change-me-to-a-long-random-string
VYNARIS_DATA_DIR=./vynaris-data
VYNARIS_ENV=dev

# Models
VYNARIS_MODEL=claude-sonnet-4-5
VYNARIS_PLANNING_MODEL=claude-opus-4-5

# ── External channels ─────────────────────────────────────────────────────────
# Each platform is optional. Leave blank to render as "coming soon" in /channels.

# Discord — the one platform fully wired for the demo.
# Create a bot at https://discord.com/developers/applications. Enable MESSAGE CONTENT intent.
# DISCORD_BOT_TOKEN=
# DISCORD_BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=...&scope=bot&permissions=274877959168

# Placeholders (not implemented yet — listed for future enablement)
# WHATSAPP_API_TOKEN=
# MSTEAMS_BOT_TOKEN=
# GCHAT_SERVICE_ACCOUNT=
# SLACK_BOT_TOKEN=

# ── Integrations ──────────────────────────────────────────────────────────────
# Gmail — required for the Connect button to appear on /integrations.
# Create OAuth credentials at https://console.cloud.google.com, redirect URI should point
# at /integrations/gmail/callback on this server.
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REDIRECT_URI=http://localhost:7878/integrations/gmail/callback

# Future integrations (placeholders)
# GOOGLE_SHEETS_CLIENT_ID=
# X_API_KEY=

# Fernet-style key for Integration config encryption. Leave blank to derive from VYNARIS_SECRET_KEY.
# INTEGRATION_ENCRYPTION_KEY=
